# ── gh-mcp configuration ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never committed.

# GitHub Personal Access Token (required)
# Create at: github.com → Settings → Developer settings →
#             Personal access tokens → Tokens (classic)
#
# Scopes needed:
#   repo        — read/write all repo content
#   read:user   — resolve your username automatically
#   delete_repo — only if you want the agent to delete repos
#   workflow    — only if you want the agent to trigger Actions
GITHUB_TOKEN=your_github_pat_here

# GitHub account owner (optional)
# Defaults to the login of whoever owns the token above.
# Override if you want to point at an org instead.
# GITHUB_OWNER=your_github_username_or_org
