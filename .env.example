# ── gh-agent configuration ────────────────────────────────────────
# Copy this to .env and fill in your values.
# .env is gitignored — never committed.

# GitHub Personal Access Token
# Create at: github.com → Settings → Developer settings → Personal access tokens → Tokens (classic)
# Scopes needed: repo, delete_repo (if you want model to delete repos)
GITHUB_TOKEN=your_github_pat_here

# Anthropic API Key
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Model to use (optional, defaults to claude-opus-4-6)
# MODEL=claude-opus-4-6
